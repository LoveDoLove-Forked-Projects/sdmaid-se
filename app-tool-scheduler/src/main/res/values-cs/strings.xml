    <string name="scheduler_setting_automation_title">Služba přístupnosti</string>
    <string name="scheduler_setting_automation_summary">Zahrnout akce, které používají službu přístupnosti. To vyžaduje, aby aplikace SD Maid mohla při provádění úloh interagovat s obrazovkou (tj. aby byla odemčená).</string>
