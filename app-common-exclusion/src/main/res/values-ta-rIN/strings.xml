    <string name="exclusion_create_pkg_hint">பயன்பாட்டு விலக்கல்களை உருவாக்க AppControl கருவியைப் பயன்படுத்தவும்.</string>
    <string name="exclusion_create_path_hint">பாதை விலக்கல்களை உருவாக்க StorageAnalyzer கருவியைப் பயன்படுத்தவும்.</string>
    <string name="exclusion_create_segment_hint">பெயர் பகுதியை பொருத்துங்கள், உதாரணமாக \"DCIM/Camera\".</string>
