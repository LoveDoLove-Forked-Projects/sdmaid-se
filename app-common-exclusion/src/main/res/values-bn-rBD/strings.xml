    <string name="exclusion_editor_affected_tools_label">প্রভাবিত টুল</string>
    <string name="exclusion_editor_path_explanation">একটি পাথ বর্জন SD Maid যেকোনো মিলিত পাথকে আরও প্রক্রিয়াকরণ করতে বাধা দেয়। এটি ফাইল, ফোল্ডার এবং সাব-ফোল্ডারের ক্ষেত্রে প্রযোজ্য।</string>
    <string name="exclusion_editor_pkg_explanation">একটি অ্যাপ বর্জন SD Maid-কে যেকোনো মিলে যাওয়া প্যাকেজ প্রক্রিয়াকরণে বাধা দেয়।</string>
    <string name="exclusion_editor_segment_explanation">একটি সেগমেন্ট ভিত্তিক বর্জন একটি পথ বর্জনের অনুরূপ কিন্তু আংশিক মিলের জন্য অনুমতি দেয়। উদাহরণ: \"DCIM/Camera\" \"/sdcard/DCIM/Camera/photo.png\" বাদ দেওয়া।</string>
    <string name="exclusion_editor_remove_confirmation_message">এই বর্জন সরাবেন?</string>
