<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="exclusion_manager_title">বর্জন ব্যবস্থাপক</string>
    <string name="exclusion_manager_desc">ফাইল এবং অ্যাপ বর্জন পরিচালনা করুন।</string>
    <string name="exclusion_explanation_body1">SD Maid এর সরঞ্জাম থেকে ফাইল এবং অ্যাপ্লিকেশন রক্ষা করতে বা অপ্রাসঙ্গিক আইটেমগুলি এড়িয়ে যেতে এবং অপারেশনগুলি দ্রুত করতে সেগুলি বাদ দিন।</string>
    <string name="exclusion_add_new_hint">এখনও কোনো বাদ দেওয়া নেই। একটি তৈরি করতে + বোতাম ব্যবহার করুন, অথবা যেকোনো সরঞ্জামের ফলাফল থেকে আইটেমগুলি বাদ দিন।</string>
