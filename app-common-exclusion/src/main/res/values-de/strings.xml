<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="exclusion_manager_title">Ausschluss-Manager</string>
    <string name="exclusion_manager_desc">Datei- und App-Ausschlüsse verwalten.</string>
    <string name="exclusion_explanation_body1">Schließen Sie Dateien und Apps aus, um sie vor SD Maids Tools zu schützen, oder überspringen Sie irrelevante Elemente und beschleunigen Sie Vorgänge.</string>
    <string name="exclusion_add_new_hint">Noch keine Ausschlüsse. Verwenden Sie die Schaltfläche +, um einen zu erstellen, oder schließen Sie Elemente aus den Ergebnissen eines beliebigen Tools aus.</string>
    <string name="exclusion_create_action">Ausschluss erstellen</string>
    <string name="exclusion_edit_action">Ausschluss bearbeiten</string>
    <string name="exclusion_type_package">App-Ausschluss</string>
    <string name="exclusion_type_path">Pfadausschluss</string>
    <string name="exclusion_type_segment">Segmentausschluss</string>
    <string name="exclusion_tags_alltools">Alle Tools</string>
    <string name="exclusion_target_label">Ausschlussobjekt</string>
    <string name="exclusion_editor_path_change_action">Tippe, um Pfad zu ändern</string>
    <string name="exclusion_option_allow_partial">Teilübereinstimmungen zulassen</string>
    <string name="exclusion_option_ignore_casing">Groß-/Kleinschreibung ignorieren</string>
    <string name="exclusion_editor_affected_tools_label">Betroffene Tools</string>
    <string name="exclusion_editor_path_explanation">Ein Pfadausschluss verhindert, dass SD Maid alle übereinstimmenden Pfade weiter verarbeitet. Dies gilt für Dateien, Verzeichnisse und Unterverzeichnisse.</string>
    <string name="exclusion_editor_pkg_explanation">Ein App-Ausschluss verhindert, dass SD Maid passende Pakete verarbeitet.</string>
    <string name="exclusion_editor_segment_explanation">Ein segmentbasierter Ausschluss ähnelt einem Pfadausschluss, ermöglicht jedoch teilweise Übereinstimmungen. Beispiel: „DCIM/Camera“ schließt „/sdcard/DCIM/Camera/photo.png“ aus.</string>
    <string name="exclusion_editor_remove_confirmation_message">Diesen Ausschluss entfernen?</string>
    <string name="exclusion_reset_default_exclusions">Wiederherstellung der standardmäßigen Ausschlüsse</string>
    <string name="exclusion_import_action">Ausschlüsse importieren</string>
    <string name="exclusion_export_action">Ausschlüsse exportieren</string>
    <string name="exclusion_create_pkg_hint">Verwende das App-Kontrolle-Tool, um App-Ausnahmen zu erstellen.</string>
    <string name="exclusion_create_path_hint">Verwende das Speicheranalyse-Tool, um Pfadausschlüsse zu erstellen.</string>
    <string name="exclusion_create_segment_hint">Stimmt mit einem Namenssegment überein, wie „DCIM/Camera“.</string>
    <string name="exclusion_show_defaults_action">Standardwerte anzeigen</string>
    <plurals name="exclusion_import_success_x_items">
        <item quantity="one">%d Ausschluss importiert</item>
        <item quantity="other">%d Ausschlüsse importiert</item>
    </plurals>
    <plurals name="exclusion_export_success_x_items">
        <item quantity="one">%d Ausschluss exportiert</item>
        <item quantity="other">%d Ausschlüsse exportiert</item>
    </plurals>
</resources>
