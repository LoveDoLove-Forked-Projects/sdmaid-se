    <string name="exclusion_type_path">Përjashtim rruge</string>
    <string name="exclusion_type_segment">Përjashtimi i segmentit</string>
    <string name="exclusion_tags_alltools">Të gjitha mjetet</string>
    <string name="exclusion_target_label">Objektivi i përjashtimit</string>
    <string name="exclusion_editor_path_change_action">Prekni për të ndryshuar shtegun</string>
    <string name="exclusion_option_allow_partial">Lejo ndeshjet e pjesshme</string>
    <string name="exclusion_option_ignore_casing">Shpërfille shkrimin me të madhe/me të vogël</string>
    <string name="exclusion_editor_affected_tools_label">Mjetet e prekura</string>
    <string name="exclusion_editor_path_explanation">Një përjashtim shtegu e pengon SD Maid të përpunojë më tej çdo shteg që përputhet. Kjo vlen për skedarët, dosjet dhe nën-dosjet.</string>
    <string name="exclusion_editor_pkg_explanation">Një përjashtim i aplikacionit pengon SD Maid të përpunojë çdo paketë që përputhet.</string>
    <string name="exclusion_editor_segment_explanation">Një përjashtim i bazuar në segment është i ngjashëm me një përjashtim shtegu, por lejon përputhje të pjesshme. Shembull: \"DCIM/Kamera\" përjashton \"/sdcard/DCIM/Camera/photo.png\".</string>
    <string name="exclusion_editor_remove_confirmation_message">Të hiqet ky përjashtim?</string>
    <string name="exclusion_reset_default_exclusions">Rivendos përjashtimet e paracaktuara</string>
    <string name="exclusion_import_action">Importo përjashtimet</string>
    <string name="exclusion_export_action">Eksporto përjashtimet</string>
    <string name="exclusion_create_pkg_hint">Përdorni mjetin AppControl për të krijuar përjashtime të aplikacioneve.</string>
    <string name="exclusion_create_path_hint">Përdorni mjetin StorageAnalyzer për të krijuar përjashtime të shtigjeve.</string>
    <string name="exclusion_create_segment_hint">Përputhni një segment emri, si \"DCIM/Camera\".</string>
    <string name="exclusion_show_defaults_action">Shfaq parazgjedhjet</string>
