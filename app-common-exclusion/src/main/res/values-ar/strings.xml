<resources>
    <string name="exclusion_manager_title">مدير الاستبعاد</string>
    <string name="exclusion_manager_desc">إدارة استثناءات الملفات والتطبيقات.</string>
    <string name="exclusion_explanation_body1">استبعد الملفات والتطبيقات لحمايتها من أدوات SD Maid، أو لتخطي العناصر غير ذات الصلة وتسريع العمليات.</string>
    <string name="exclusion_add_new_hint">لا توجد استثناءات حتى الآن. استخدم زر + لإنشاء واحد، أو استبعد العناصر من نتائج أي أداة.</string>
