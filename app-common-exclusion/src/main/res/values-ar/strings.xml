    <string name="exclusion_create_pkg_hint">استخدم أداة التحكم في التطبيقات لإنشاء استثناءات التطبيق.</string>
    <string name="exclusion_create_path_hint">استخدم أداة \"محلل التخزين\" لإنشاء استثناءات المسار.</string>
    <string name="exclusion_create_segment_hint">طابق جزءاً من الاسم، مثل \"DCIM/Camera\".</string>
