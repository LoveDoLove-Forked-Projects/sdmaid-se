<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="exclusion_manager_title">Administrador de exclusión</string>
    <string name="exclusion_manager_desc">Administrar las exclusiones de archivos y aplicaciones.</string>
    <string name="exclusion_explanation_body1">Excluí archivos y aplicaciones para protegerlos de las herramientas de SD Maid, o para saltarte elementos irrelevantes y acelerar las operaciones.</string>
    <string name="exclusion_add_new_hint">Sin exclusiones aún. Usá el botón + para crear una, o excluí elementos de los resultados de cualquier herramienta.</string>
    <string name="exclusion_create_action">Crear una exclusión</string>
    <string name="exclusion_edit_action">Editar la exclusión</string>
    <string name="exclusion_type_package">Exclusión de aplicación</string>
    <string name="exclusion_type_path">Exclusión de ruta</string>
    <string name="exclusion_type_segment">Excluir por partes</string>
    <string name="exclusion_tags_alltools">Todas las herramientas</string>
    <string name="exclusion_target_label">Objetivo de la exclusión</string>
    <string name="exclusion_editor_path_change_action">Tocá para cambiar la ruta</string>
    <string name="exclusion_option_allow_partial">Permitir las coincidencias parciales</string>
    <string name="exclusion_option_ignore_casing">Ignorar carcasa</string>
    <string name="exclusion_editor_affected_tools_label">Herramientas afectadas</string>
    <string name="exclusion_editor_path_explanation">Una exclusión de rutas evita que SD Maid procese más cualquier ruta que coincida. Esto se aplica a archivos, carpetas y subcarpetas.</string>
    <string name="exclusion_editor_pkg_explanation">Una exclusión de la aplicación impide que SD Maid procese los paquetes coincidentes.</string>
    <string name="exclusion_editor_segment_explanation">Una exclusión basada en segmentos es similar a una exclusión de ruta, pero permite coincidencias parciales. Por ejemplo: \"DCIM/Camera\" excluye \"/sdcard/DCIM/Camera/photo.png\".</string>
    <string name="exclusion_editor_remove_confirmation_message">¿Eliminar esta exclusión?</string>
    <string name="exclusion_reset_default_exclusions">Restaurar las exclusiones por defecto</string>
    <string name="exclusion_import_action">Importar exclusiones</string>
    <string name="exclusion_export_action">Exportar exclusiones</string>
    <string name="exclusion_create_pkg_hint">Usa la herramienta AppControl para crear exclusiones de las aplicaciones.</string>
    <string name="exclusion_create_path_hint">Utiliza la herramienta StorageAnalyzer para crear exclusiones de rutas.</string>
    <string name="exclusion_create_segment_hint">Coincidir con un segmento de nombre, como \"DCIM/Camera\".</string>
    <string name="exclusion_show_defaults_action">Mostrar predeterminados</string>
    <plurals name="exclusion_import_success_x_items">
        <item quantity="one">%d exclusión importada</item>
        <item quantity="other">%d exclusiones importadas</item>
    </plurals>
    <plurals name="exclusion_export_success_x_items">
        <item quantity="one">%d exclusión exportada</item>
        <item quantity="other">%d exclusiones exportadas</item>
    </plurals>
</resources>
