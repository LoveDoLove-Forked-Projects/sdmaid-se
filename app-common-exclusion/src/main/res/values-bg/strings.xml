<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="exclusion_manager_title">Мениджър на изключения</string>
    <string name="exclusion_manager_desc">Управление на изключения на файлове и приложения.</string>
    <string name="exclusion_explanation_body1">Изключете файлове и приложения, за да ги защитите от инструментите на SD Maid, или прескочете неуместни елементи и ускорете операциите.</string>
    <string name="exclusion_add_new_hint">Все още няма изключвания. Използвайте бутона +, за да създадете едно, или изключете елементи от резултатите на който и да е инструмент.</string>
    <string name="exclusion_create_action">Създаване на изключение</string>
    <string name="exclusion_edit_action">Редактиране на изключение</string>
    <string name="exclusion_type_package">Изключване на приложение</string>
    <string name="exclusion_type_path">Изключване на път</string>
    <string name="exclusion_type_segment">Изключване на сегмент</string>
    <string name="exclusion_tags_alltools">Всички инструменти</string>
    <string name="exclusion_target_label">Цел на изключване</string>
    <string name="exclusion_editor_path_change_action">Докоснете за промяна на пътя</string>
    <string name="exclusion_option_allow_partial">Разрешаване на частични съвпадения</string>
    <string name="exclusion_option_ignore_casing">Игнориране на регистъра</string>
    <string name="exclusion_editor_affected_tools_label">Засегнати инструменти</string>
    <string name="exclusion_editor_path_explanation">Изключването на път предотвратява SD Maid от по-нататъшна обработка на всякакви съвпадащи пътища. Това се отнася за файлове, папки и подпапки.</string>
    <string name="exclusion_editor_pkg_explanation">Изключването на приложение предотвратява SD Maid от обработка на всякакви съвпадащи пакети.</string>
    <string name="exclusion_editor_segment_explanation">Изключването, базирано на сегмент, е подобно на изключването на път, но позволява частични съвпадения. Пример: \"DCIM/Camera\" изключва \"/sdcard/DCIM/Camera/photo.png\".</string>
    <string name="exclusion_editor_remove_confirmation_message">Премахване на това изключване?</string>
    <string name="exclusion_reset_default_exclusions">Възстановяване на изключенията по подразбиране</string>
    <string name="exclusion_import_action">Импортиране на изключения</string>
    <string name="exclusion_export_action">Експортиране на изключения</string>
    <string name="exclusion_create_pkg_hint">Използвайте инструмента AppControl за създаване на изключения за приложения.</string>
    <string name="exclusion_create_path_hint">Използвайте инструмента StorageAnalyzer за създаване на изключения за пътища.</string>
    <string name="exclusion_create_segment_hint">Съвпадение с част от името, напр. „DCIM/Camera“.</string>
    <string name="exclusion_show_defaults_action">Показване на стандартните</string>
    <plurals name="exclusion_import_success_x_items">
        <item quantity="one">%d изключване е импортирано</item>
        <item quantity="other">%d изключвания са импортирани</item>
    </plurals>
    <plurals name="exclusion_export_success_x_items">
        <item quantity="one">%d изключване е експортирано</item>
        <item quantity="other">%d изключвания са експортирани</item>
    </plurals>
</resources>
