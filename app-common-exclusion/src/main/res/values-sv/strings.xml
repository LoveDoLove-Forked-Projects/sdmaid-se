    <string name="exclusion_editor_segment_explanation">En segmentbaserad uteslutning liknar en sökvägsuteslutning men tillåter partiella matchningar. Exempel: \"DCIM/Camera\" utesluter \"/sdcard/DCIM/Camera/photo.png\".</string>
