<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="exclusion_manager_title">Gestionnaire d’exclusions</string>
    <string name="exclusion_manager_desc">Gérer les exclusions de fichiers et d’applis.</string>
    <string name="exclusion_explanation_body1">Excluez des fichiers et des applis pour les protéger des outils de SD Maid, ou pour ignorer les éléments non pertinents et accélérer les opérations.</string>
    <string name="exclusion_add_new_hint">Aucune exclusion pour le moment. Utilisez le bouton + pour en créer une, ou excluez des éléments de n’importe quel résultat d’outil.</string>
    <string name="exclusion_create_action">Créer une exclusion</string>
    <string name="exclusion_edit_action">Modifier l’exclusion</string>
    <string name="exclusion_type_package">Exclusion d’applis</string>
    <string name="exclusion_type_path">Exclusion de chemins</string>
    <string name="exclusion_type_segment">Exclusion de segments</string>
    <string name="exclusion_tags_alltools">Tous les outils</string>
    <string name="exclusion_target_label">Cible de l’exclusion</string>
    <string name="exclusion_editor_path_change_action">Toucher pour changer le chemin</string>
    <string name="exclusion_option_allow_partial">Autoriser les correspondances partielles</string>
    <string name="exclusion_option_ignore_casing">Ignorer la casse</string>
    <string name="exclusion_editor_affected_tools_label">Outils affectés</string>
    <string name="exclusion_editor_path_explanation">L\'exclusion d’un chemin empêche SD Maid de poursuivre le traitement des chemins correspondants. Cela s\'applique aux fichiers, aux dossiers et aux sous-dossiers.</string>
    <string name="exclusion_editor_pkg_explanation">L’exclusion d’une appli empêche SD Maid de traiter les paquets correspondants.</string>
    <string name="exclusion_editor_segment_explanation">Une exclusion d’après le segment s’apparente à l’exclusion d’un chemin, mais permet des correspondances partielles. Par exemple, « DCIM/Camera » exclut « /sdcard/DCIM/Camera/photo.png ».</string>
    <string name="exclusion_editor_remove_confirmation_message">Supprimer cette exclusion ?</string>
    <string name="exclusion_reset_default_exclusions">Rétablir les exclusions par défaut</string>
    <string name="exclusion_import_action">Importer des exclusions</string>
    <string name="exclusion_export_action">Exporter les exclusions</string>
    <string name="exclusion_create_pkg_hint">Utilisez le « Vérificateur d’applis » pour exclure des applis.</string>
    <string name="exclusion_create_path_hint">Utilisez l’« Analyseur de mémoire » pour exclure des chemins.</string>
    <string name="exclusion_create_segment_hint">Correspondre à un segment de nom, comme « DCIM/Camera ».</string>
    <string name="exclusion_show_defaults_action">Afficher les valeurs par défaut</string>
