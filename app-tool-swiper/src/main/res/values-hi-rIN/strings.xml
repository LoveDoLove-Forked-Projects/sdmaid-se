    <!-- Guided tour -->
    <string name="tour_swiper_gestures_body">किसी फ़ोटो को स्वाइप करें और इसका भाग्य तय करें: बगल में रखने या हटाने के लिए, ऊपर स्किप करने के लिए, नीचे पूर्ववत करने के लिए। नीचे दिए गए बटन भी वही करते हैं — और दिखाते हैं कि कौन सी तरफ कौन सी है।</string>
    <string name="tour_swiper_openin_body">यह बटन फ़ोटो को किसी अन्य ऐप में खोलता है, तय करने से पहले इसकी जांच के लिए उपयोगी है।</string>
    <string name="tour_swiper_preview_body">यह बटन अधिक बारीकी से देखने के लिए पूर्ण-स्क्रीन पूर्वावलोकन खोलता है।</string>
    <string name="tour_swiper_actions_body">स्वाइपिंग पसंद नहीं? हमारे पास बटन भी हैं! स्किप इसे बाद के लिए अनिर्णीत रखता है, और स्किप को लंबे समय तक दबाने से भविष्य की स्कैन से किसी फ़ाइल को बाहर रखा जाता है। पूर्ववत आपकी पिछली पसंद को वापस करता है।</string>
    <string name="tour_swiper_review_body">आपकी रखने और हटाने की पसंद केवल चरणबद्ध हैं। उन्हें देखने के लिए समीक्षा खोलें और जब आप तैयार हों तो हटाना लागू करें।</string>
</resources>
