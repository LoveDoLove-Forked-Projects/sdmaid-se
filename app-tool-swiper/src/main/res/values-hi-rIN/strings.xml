<resources>
    <string name="swiper_label">Swiper</string>
    <string name="swiper_tool_description">फ़ोल्डरों को जल्दी साफ करें — फ़ाइलों को रखने, हटाने या छोड़ने के लिए स्वाइप करें।</string>
    <string name="swiper_dashcard_description">फ़ाइल एक्सप्लोरर से तेज़ — बस हर फ़ाइल को स्वाइप करके विशिष्ट फ़ोल्डरों को व्यवस्थित करें।</string>
    <string name="swiper_start_action">स्वाइप शुरू करें</string>
    <string name="swiper_continue_action">सत्र जारी रखें</string>
    <string name="swiper_sessions_description">3 आसान चरणों में फ़ाइलों की समीक्षा करें:\n\n1. स्कैन करने के लिए एक फ़ोल्डर चुनें\n2. फ़ाइलों को रखने, हटाने या छोड़ने के लिए स्वाइप करें\n3. अपने विकल्पों की समीक्षा करें और पुष्टि करें\n\nजब तक आप अंतिम हटाएं बटन नहीं दबाते, कुछ भी नहीं हटाया जाता।</string>
