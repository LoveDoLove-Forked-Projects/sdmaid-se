    <!-- Guided tour -->
    <string name="tour_swiper_gestures_body">Svirp en fil for at bestemme dens skæbne: til siden for at beholde eller slette, op for at springe over, ned for at fortryde. Knapperne nedenfor gør det samme — og viser hvilken side som hvad.</string>
    <string name="tour_swiper_openin_body">Denne knap åbner filen i en anden app, praktisk til at tjekke den før du beslutter.</string>
    <string name="tour_swiper_preview_body">Denne knap åbner en fuldskærmsfremvisning for et nærmere blik.</string>
    <string name="tour_swiper_actions_body">Kan du ikke lide at svirpe? Vi har også knapper! Spring over efterlader det uafgjort til senere, og langtryk på Spring over udelukker en fil fra kommende skanninger. Fortryd tilbagefører dit sidste valg.</string>
    <string name="tour_swiper_review_body">Dine valg for bevarelse og sletning er kun midlertidigt gemt. Åbn Gennemgang for at gennemgå dem og anvende sletningerne når du er klar.</string>
