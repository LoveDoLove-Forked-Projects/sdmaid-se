    <string name="swiper_delete_confirmation_checkbox">இந்த கோப்புகள் நிரந்தரமாக நீக்கப்படும் என்பதை நான் புரிந்துகொண்டுள்ளேன்.</string>
    <string name="swiper_sensitive_root_warning_title">முழு சேமிப்பகத்தையும் ஸ்கேன் செய்யவா?</string>
    <string name="swiper_sensitive_root_warning_message">%1$s ஐ ஸ்கேன் செய்வது இந்த சேமிப்பகத்திலுள்ள ஒவ்வொரு கோப்பையும் உள்ளடக்குகிறது — புகைப்படங்கள், ஆவணங்கள், பதிவிறக்கங்கள், பயன்பாட்டு மீடியா மற்றும் பல. தொடர்க?</string>
    <string name="swiper_sensitive_root_warning_continue_action">எப்படியும் தொடரவும்</string>
    <string name="swiper_session_risky_label">முழு சேமிப்பக ஸ்கேன்</string>
    <string name="swiper_session_risky_info_message">இந்த அமர்வு சேமிப்பக தொகுதியின் மூலத்தை இலக்கிட்டுள்ளது, எனவே அந்த சேமிப்பகத்திலுள்ள ஒவ்வொரு கோப்பும் நோக்கத்திற்குள் உள்ளது — புகைப்படங்கள், ஆவணங்கள், பதிவிறக்கங்கள், பயன்பாட்டு மீடியா மற்றும் பல.\n\nமுழு சேமிப்பக ஸ்கேன்கள் பல உருப்படிகளை தரலாம், நீங்கள் மதிப்பாய்வு செய்யாமல் இருக்கக்கூடிய கோப்புகள் உட்பட. ஸ்கேனைச் சுருக்க ஒரு கோப்பு-வகை வடிப்பலைப் பயன்படுத்தவும்.</string>
    <string name="swiper_delete_x_action">%1$d நீக்கு</string>
    <string name="swiper_settings_swap_directions_title">ஸ்வைப் திசைகளை மாற்று</string>
    <string name="swiper_settings_swap_directions_summary">வைத்திருக்க இடமாகவும், நீக்க வலமாகவும் ஸ்வைப் செய்.</string>
    <string name="swiper_settings_show_details_title">கோப்பு விவரங்களைக் காட்டு</string>
