    <!-- Guided tour -->
    <string name="tour_swiper_gestures_body">ஒரு கோப்பை வருடவவும் அதன் நிலை முடிவு செய்ய: பக்கவாக வைத்திருக்க அல்லது நீக்க, மேலே தவிர்க்க, கீழே ஸ்வைப் செய்ததை திருப்ப. கீழே உள்ள பொத்தான்கள் அதையே செய்கின்றன — மற்றும் எந்த பக்கம் எது என்பதைக் காட்டுகின்றன.</string>
    <string name="tour_swiper_openin_body">இந்த பொத்தான் கோப்பை மற்றொரு பயன்பாட்டில் திறக்கிறது, முடிவு செய்வதற்கு முன் அதை சரிபார்க்க பயனுள்ளதாக உள்ளது.</string>
    <string name="tour_swiper_preview_body">இந்த பொத்தான் முழு திரை முன்னோட்டத்தைத் திறக்கிறது, நெருக்கமாக பார்ப்பதற்கு.</string>
    <string name="tour_swiper_actions_body">ஏஸ்வைப் செய்ய விருப்பவில்லையா? எங்களிடம் பொத்தான்களும் உள்ளன! தவிர் பொத்தான் இதைப் பிறகு தீர்மானிக்கவும் வைக்கிறது, மேலும் தவிர் பொத்தானை நீண்ட நேரம் அழுத்துவது ஒரு கோப்பைப் பிறகான ஸ்கேன்களிலிருந்து விலக்குகிறது. செயல்ரத்து உங்கள் கடைசி தேர்வை மாற்றுகிறது.</string>
    <string name="tour_swiper_review_body">உங்கள் வைக்க மற்றும் நீக்க விருப்பங்கள் மட்டும் தயாரிக்கப்பட்டுள்ளன. மதிப்பாய்வைத் திறந்து அவற்றை மீண்டும் பார்க்கவும், நீங்கள் தயாரானபின் நீக்கலைப் பயன்படுத்தவும்.</string>
