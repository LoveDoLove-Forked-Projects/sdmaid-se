    <!-- Config backup/restore errors -->
    <string name="backup_restore_error_invalid_title">Μη έγκυρο αρχείο αντιγράφου ασφαλείας</string>
    <string name="backup_restore_error_invalid_body">Αυτό το αρχείο δεν είναι έγκυρο αντίγραφο ασφαλείας του SD Maid ή είναι κατεστραμμένο.</string>
    <string name="backup_restore_error_version_body">Αυτό το αντίγραφο ασφαλείας δημιουργήθηκε με μια νεότερη έκδοση του SD Maid. Ενημερώστε την εφαρμογή και προσπαθήστε ξανά.</string>
    <string name="backup_restore_error_restore_failed_title">Η επαναφορά απέτυχε</string>
    <string name="backup_restore_error_restore_failed_body">Αυτά τα μέρη δεν μπόρεσαν να επαναφερθούν: %1$s. Η προηγούμενη διαμόρφωσή σας έχει αποθηκευτεί και μπορεί να επαναφερθεί.</string>
    <string name="backup_restore_error_safety_title">Η επαναφορά δεν ξεκίνησε</string>
    <string name="backup_restore_error_safety_body">Το SD Maid δεν μπόρεσε να αποθηκεύσει ένα στιγμιότυπο ασφαλείας της τρέχουσας διαμόρφωσής σας, γι\' αυτό δεν άλλαξε τίποτα.</string>
    <string name="backup_restore_error_busy_title">Παρακαλώ περιμένετε</string>
    <string name="backup_restore_error_busy_body">Μια εργασία καθαρισμού ή μια άλλη λειτουργία αντιγράφου ασφαλείας εκτελείται αυτήν τη στιγμή. Δοκιμάστε ξανά όταν τελειώσει.</string>
    <string name="backup_restore_error_schema_title">Ασύμβατο αντίγραφο ασφαλείας</string>
    <string name="backup_restore_error_schema_body">Η μορφή βάσης δεδομένων του αντιγράφου ασφαλείας δεν ταιριάζει με αυτήν την έκδοση του SD Maid. Η επαναφορά δεδομένων ιστορικού υποστηρίζεται μόνο μεταξύ πανομοιότυπων εκδόσεων εφαρμογής.</string>
