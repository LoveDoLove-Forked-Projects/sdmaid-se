    <string name="backup_restore_error_invalid_title">Fichier de sauvegarde invalide</string>
    <string name="backup_restore_error_invalid_body">Ce fichier n’est pas une sauvegarde SD Maid valide ou est corrompu.</string>
    <string name="backup_restore_error_version_body">Cette sauvegarde a été créée avec une version plus récente de SD Maid. Veuillez mettre à jour l’application et réessayer.</string>
    <string name="backup_restore_error_restore_failed_title">La restauration a échoué</string>
    <string name="backup_restore_error_restore_failed_body">Ces parties n’ont pas pu être restaurées : %1$s. Votre configuration précédente a été sauvegardée et peut être restaurée.</string>
    <string name="backup_restore_error_safety_title">Restauration non démarrée</string>
    <string name="backup_restore_error_safety_body">SD Maid n’a pas pu créer une sauvegarde de sécurité de votre configuration actuelle, c’est pourquoi rien n’a été modifié.</string>
    <string name="backup_restore_error_busy_title">Veuillez patienter</string>
    <string name="backup_restore_error_busy_body">Une tâche de nettoyage ou une autre opération de sauvegarde est actuellement en cours. Réessayez quand elle sera terminée.</string>
    <string name="backup_restore_error_schema_title">Sauvegarde incompatible</string>
    <string name="backup_restore_error_schema_body">Le format de base de données de la sauvegarde ne correspond pas à cette version de SD Maid. La restauration des données historiques n’est prise en charge qu’entre les versions identiques de l’appli.</string>
