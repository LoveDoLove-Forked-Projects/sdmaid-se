    <!-- Config backup/restore errors -->
    <string name="backup_restore_error_invalid_title">അസാധുവായ ബാക്കപ്പ് ഫയൽ</string>
    <string name="backup_restore_error_invalid_body">ഈ ഫയൽ സാധുവായ SD Maid ബാക്കപ്പ് അല്ലെങ്കിൽ കേടായതാണ്.</string>
    <string name="backup_restore_error_version_body">ഈ ബാക്കപ്പ് SD Maid യുടെ ഒരു പുതിയ പതിപ്പ് ഉപയോഗിച്ച് സൃഷ്ടിക്കപ്പെട്ടു. ദയവായി അപ്ലിക്കേഷൻ അപ്ഡേറ്റ് ചെയ്യുക കൂടാതെ വീണ്ടും ശ്രമിക്കുക.</string>
    <string name="backup_restore_error_restore_failed_title">പുനഃസ്ഥാപനം പരാജയപ്പെട്ടു</string>
    <string name="backup_restore_error_restore_failed_body">ഈ ഭാഗങ്ങൾ പുനഃസ്ഥാപിക്കാൻ കഴിഞ്ഞില്ല: %1$s. നിങ്ങളുടെ മുമ്പത്തെ ക്രമീകരണം സംരക്ഷിക്കപ്പെട്ട് തിരികെ കൊണ്ടുവരാൻ കഴിയും.</string>
    <string name="backup_restore_error_safety_title">പുനഃസ്ഥാപനം ആരംഭിക്കപ്പെട്ടില്ല</string>
    <string name="backup_restore_error_safety_body">SD Maid നിങ്ങളുടെ നിലവിലെ ക്രമീകരണത്തിന്റെ ഒരു സുരക്ഷാ സ്നാപ്പ്‌ഷോട്ട് സംരക്ഷിക്കാൻ കഴിഞ്ഞില്ല, അതിനാൽ ഒന്നും മാറ്റപ്പെട്ടില്ല.</string>
    <string name="backup_restore_error_busy_title">ദയവായി കാത്തിരിക്കുക</string>
    <string name="backup_restore_error_busy_body">ഒരു ശുദ്ധിയന്ത്രണ ജോലി അല്ലെങ്കിൽ മറ്റൊരു ബാക്കപ്പ് പ്രവർത്തനം നിലവിൽ പ്രവർത്തിക്കുകയാണ്. അത് പൂർത്തിയായിക്കഴിഞ്ഞാൽ വീണ്ടും ശ്രമിക്കുക.</string>
    <string name="backup_restore_error_schema_title">അനുയോജ്യമല്ലാത്ത ബാക്കപ്പ്</string>
    <string name="backup_restore_error_schema_body">ബാക്കപ്പിന്റെ ഡാറ്റാബേസ് ഫോർമാറ്റ് SD Maid ന്റെ ഈ പതിപ്പുമായി പൊരുത്തപ്പെടുന്നില്ല. ചരിത്ര ഡാറ്റ പുനഃസ്ഥാപനം സമാന അപ്ലിക്കേഷൻ പതിപ്പുകള് തമ്മിൽ മാത്രം പിന്തുണയ്ക്കപ്പെടുന്നു.</string>
