    <string name="backup_restore_error_invalid_title">Ficheiro de copia de seguridade non válido</string>
    <string name="backup_restore_error_invalid_body">Este ficheiro non é unha copia de seguridade válida de SD Maid ou está corrompido.</string>
    <string name="backup_restore_error_version_body">Esta copia de seguridade foi creada cunha versión máis recente de SD Maid. Por favor, actualiza a aplicación e intenta de novo.</string>
    <string name="backup_restore_error_restore_failed_title">Fallou a restauración</string>
    <string name="backup_restore_error_restore_failed_body">Non se puido restaurar estas partes: %1$s. A túa configuración anterior foi gardada e pode ser recuperada.</string>
    <string name="backup_restore_error_safety_title">A restauración non se iniciou</string>
    <string name="backup_restore_error_safety_body">SD Maid non puido gardar unha instantánea de seguridade da túa configuración actual, polo que non se cambiou nada.</string>
    <string name="backup_restore_error_busy_title">Por favor, agarda</string>
    <string name="backup_restore_error_busy_body">Unha tarefa de limpeza ou outra operación de copia de seguridade está en execución. Tenta de novo cando remate.</string>
    <string name="backup_restore_error_schema_title">Copia de seguridade non compatible</string>
    <string name="backup_restore_error_schema_body">O formato da base de datos da copia de seguridade non coincide con esta versión de SD Maid. Restaurar datos do historial só se admite entre versións idénticas da aplicación.</string>
