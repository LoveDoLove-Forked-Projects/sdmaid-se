    <string name="backup_restore_error_invalid_title">Ungültige Sicherungsdatei</string>
    <string name="backup_restore_error_invalid_body">Diese Datei ist keine gültige SD Maid-Sicherung oder ist beschädigt.</string>
    <string name="backup_restore_error_version_body">Dieses Backup wurde mit einer neueren Version von SD Maid erstellt. Bitte aktualisiere die App und versuche es erneut.</string>
    <string name="backup_restore_error_restore_failed_title">Wiederherstellung fehlgeschlagen</string>
    <string name="backup_restore_error_restore_failed_body">Diese Teile konnten nicht wiederhergestellt werden: %1$s. Deine vorherige Konfiguration wurde gespeichert und kann wiederhergestellt werden.</string>
    <string name="backup_restore_error_safety_title">Wiederherstellung nicht gestartet</string>
    <string name="backup_restore_error_safety_body">SD Maid konnte kein Sicherheits-Snapshot deiner aktuellen Konfiguration speichern, daher wurde nichts verändert.</string>
    <string name="backup_restore_error_busy_title">Bitte warten</string>
    <string name="backup_restore_error_busy_body">Ein Reinigungs- oder anderer Sicherungsvorgang läuft derzeit. Versuche es erneut, wenn er abgeschlossen ist.</string>
    <string name="backup_restore_error_schema_title">Inkompatible Sicherung</string>
    <string name="backup_restore_error_schema_body">Das Datenbankformat des Backups passt nicht zu dieser Version von SD Maid. Das Wiederherstellen von Verlaufsdaten wird nur zwischen identischen App-Versionen unterstützt.</string>
