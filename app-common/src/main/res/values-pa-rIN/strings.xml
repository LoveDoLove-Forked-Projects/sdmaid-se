    <!-- Config backup/restore errors -->
    <string name="backup_restore_error_invalid_title">ਅਵੈਧ ਬੈਕਅੱਪ ਫਾਇਲ</string>
    <string name="backup_restore_error_invalid_body">ਇਹ ਫਾਇਲ ਇੱਕ ਵੈਧ SD Maid ਬੈਕਅੱਪ ਨਹੀਂ ਹੈ ਜਾਂ ਖਰਾਬ ਹੈ।</string>
    <string name="backup_restore_error_version_body">ਇਹ ਬੈਕਅੱਪ SD Maid ਦੇ ਇੱਕ ਨਵੇਂ ਸੰਸਕਰਣ ਨਾਲ ਬਣਾਇਆ ਗਿਆ ਸੀ। ਕਿਰਪਾ ਕਰਕੇ ਐਪ ਨੂੰ ਅੱਪਡੇਟ ਕਰੋ ਅਤੇ ਦੁਬਾਰਾ ਕੋਸ਼ਿਸ਼ ਕਰੋ।</string>
    <string name="backup_restore_error_restore_failed_title">ਬਹਾਲੀ ਅਸਫਲ</string>
    <string name="backup_restore_error_restore_failed_body">ਇਹ ਹਿੱਸੇ ਬਹਾਲ ਨਹੀਂ ਕੀਤੇ ਜਾ ਸਕੇ: %1$s। ਤੁਹਾਡੀ ਪਿਛਲੀ ਸੰਰਚਨਾ ਸੁਰੱਖਿਅਤ ਕੀਤੀ ਗਈ ਸੀ ਅਤੇ ਵਾਪਸ ਲਿਆਂਦੀ ਜਾ ਸਕਦੀ ਹੈ।</string>
    <string name="backup_restore_error_safety_title">ਬਹਾਲੀ ਸ਼ੁਰੂ ਨਹੀਂ ਹੋਈ</string>
    <string name="backup_restore_error_safety_body">SD Maid ਤੁਹਾਡੀ ਮੌਜੂਦਾ ਸੰਰਚਨਾ ਦਾ ਸੁਰੱਖਿਆ ਸਨੈਪਸ਼ਾਟ ਸੁਰੱਖਿਤ ਨਹੀਂ ਕਰ ਸਕਿਆ, ਇਸਲਈ ਕੋਈ ਵੀ ਤਬਦੀਲੀ ਨਹੀਂ ਕੀਤੀ ਗਈ।</string>
    <string name="backup_restore_error_busy_title">ਕਿਰਪਾ ਕਰਕੇ ਉਡੀਕ ਕਰੋ</string>
    <string name="backup_restore_error_busy_body">ਇੱਕ ਸਾਫ਼ ਕਰਨ ਦੀ ਕਾਰਵਾਈ ਜਾਂ ਕੋਈ ਹੋਰ ਬੈਕਅੱਪ ਕਾਰਵਾਈ ਵਰਤਮਾਨ ਵਿੱਚ ਚੱਲ ਰਹੀ ਹੈ। ਇਹ ਪੂਰੀ ਹੋਣ ਤੋਂ ਬਾਅਦ ਦੁਬਾਰਾ ਕੋਸ਼ਿਸ਼ ਕਰੋ।</string>
    <string name="backup_restore_error_schema_title">ਅਸੰਗਤ ਬੈਕਅੱਪ</string>
    <string name="backup_restore_error_schema_body">ਬੈਕਅੱਪ ਦਾ ਡੇਟਾਬੇਸ ਫਾਰਮੈਟ SD Maid ਦੇ ਇਸ ਸੰਸਕਰਣ ਨਾਲ ਮੇਲ ਨਹੀਂ ਖਾਂਦਾ। ਇਤਿਹਾਸ ਡੇਟਾ ਨੂੰ ਮੁੜ ਬਹਾਲ ਕਰਨਾ ਸਿਰਫ ਇੱਕੋ ਜਿਹੇ ਐਪ ਸੰਸਕਰਣਾਂ ਦੇ ਵਿਚਕਾਰ ਹੀ ਸਮਰਥਿਤ ਹੈ।</string>
