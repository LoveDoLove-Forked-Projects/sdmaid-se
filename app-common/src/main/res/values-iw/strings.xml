    <!-- Config backup/restore errors -->
    <string name="backup_restore_error_invalid_title">קובץ גיבוי שגוי</string>
    <string name="backup_restore_error_invalid_body">קובץ זה אינו קובץ גיבוי חוקי של SD Maid או שהוא פגום.</string>
    <string name="backup_restore_error_version_body">גיבוי זה נוצר בגרסה חדשה יותר של SD Maid. אנא עדכן את האפליקציה ונסה שוב.</string>
    <string name="backup_restore_error_restore_failed_title">שחזור נכשל</string>
    <string name="backup_restore_error_restore_failed_body">חלקים אלה לא יכלו להיות מושחזרים: %1$s. התצורה הקודמת שלך נשמרה וניתן להחזירה.</string>
    <string name="backup_restore_error_safety_title">השחזור לא התחיל</string>
    <string name="backup_restore_error_safety_body">SD Maid לא הצליחה לשמור תמונת בטיחות של התצורה הנוכחית שלך, לכן דבר לא שונה.</string>
    <string name="backup_restore_error_busy_title">אנא המתן</string>
    <string name="backup_restore_error_busy_body">משימת ניקיון או פעולת גיבוי אחרת פועלת כעת. נסה שוב כשהיא תסתיים.</string>
    <string name="backup_restore_error_schema_title">גיבוי לא תואם</string>
    <string name="backup_restore_error_schema_body">פורמט מסד הנתונים של הגיבוי לא תואם לגרסה זו של SD Maid. שחזור נתוני ההיסטוריה נתמך רק בין גרסאות אפליקציה זהות.</string>
