    <string name="backup_restore_error_busy_title">براہ کرم انتظار کریں</string>
    <string name="backup_restore_error_busy_body">ایک صفائی کا کام یا دوسری بیک اپ کی کارروائی فی الوقت چل رہی ہے۔ جب یہ مکمل ہو جائے تو دوبارہ کوشش کریں۔</string>
