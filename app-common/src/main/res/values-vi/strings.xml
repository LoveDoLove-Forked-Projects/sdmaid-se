    <!-- Config backup/restore errors -->
    <string name="backup_restore_error_invalid_title">Tệp sao lưu không hợp lệ</string>
    <string name="backup_restore_error_invalid_body">Tệp này không phải là một bản sao lưu SD Maid hợp lệ hoặc bị hỏng.</string>
    <string name="backup_restore_error_version_body">Bản sao lưu này được tạo với phiên bản SD Maid mới hơn. Vui lòng cập nhật ứng dụng và thử lại.</string>
    <string name="backup_restore_error_restore_failed_title">Khôi phục không thành công</string>
    <string name="backup_restore_error_restore_failed_body">Các phần này không thể được khôi phục: %1$s. Cấu hình trước đây của bạn đã được lưu và có thể được khôi phục.</string>
    <string name="backup_restore_error_safety_title">Khôi phục chưa bắt đầu</string>
    <string name="backup_restore_error_safety_body">SD Maid không thể lưu ảnh chụp an toàn của cấu hình hiện tại của bạn, vì vậy không có gì thay đổi.</string>
    <string name="backup_restore_error_busy_title">Vui lòng chờ</string>
    <string name="backup_restore_error_busy_body">Một tác vụ dọn dẹp hoặc hoạt động sao lưu khác đang chạy. Hãy thử lại khi nó hoàn thành.</string>
    <string name="backup_restore_error_schema_title">Sao lưu không tương thích</string>
    <string name="backup_restore_error_schema_body">Định dạng cơ sở dữ liệu của sao lưu không khớp với phiên bản SD Maid này. Khôi phục dữ liệu lịch sử chỉ được hỗ trợ giữa các phiên bản ứng dụng giống hệt nhau.</string>
