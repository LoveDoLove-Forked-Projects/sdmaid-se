    <!-- Shown when a feature can only run with privileged access that turned out to be unavailable. -->
    <string name="access_blocked_root_unavailable">Kjo veçori kërkon qasje rrënjë, por SD Maid nuk mund ta merrte në këtë pajisje.</string>
    <string name="access_blocked_root_declined">Kjo veçori kërkon akses root. Mund ta aktivizoni përmes ekranit të konfigurimit.</string>
    <string name="access_blocked_root_or_shizuku">Kjo veçori kërkon akses root ose Shizuku, i cili nuk është i disponueshëm në këtë pajisje.</string>
    <!-- Config backup/restore errors -->
    <string name="backup_restore_error_invalid_title">Skedar kopjeje sigurie jo i vlefshëm</string>
    <string name="backup_restore_error_invalid_body">Ky skedar nuk është një kopje sigurie e vlefshme SD Maid ose është i korruptuar.</string>
    <string name="backup_restore_error_version_body">Kjo kopje sigurie u krijua me një version më të ri të SD Maid. Ju lutemi përditësoni aplikacionin dhe provoni përsëri.</string>
    <string name="backup_restore_error_restore_failed_title">Rivendosja dështoi</string>
    <string name="backup_restore_error_restore_failed_body">Këto pjesë nuk mund të rivendosen: %1$s. Konfigurimi i mëparshëm u ruajt dhe mund të kthehet.</string>
    <string name="backup_restore_error_safety_title">Rivendosja nuk ka filluar</string>
    <string name="backup_restore_error_safety_body">SD Maid nuk arriti të ruante një pamje të sigurt të konfigurimit tuaj aktual, kështu që asgjë nuk u ndryshua.</string>
    <string name="backup_restore_error_busy_title">Ju lutemi prisni</string>
    <string name="backup_restore_error_busy_body">Një detyrë pastrimi ose një operacion tjetër kopje rezerve po xhirohet aktualisht. Përpiquni përsëri kur të ketë përfunduar.</string>
    <string name="backup_restore_error_schema_title">Kopja rezerve e papajtueshme</string>
    <string name="backup_restore_error_schema_body">Formati i bazës së të dhënave të kopjes rezerve nuk përputhet me këtë version të SD Maid. Rivendosja e të dhënave të historikut mbështetet vetëm midis versioneve identike të aplikacionit.</string>
