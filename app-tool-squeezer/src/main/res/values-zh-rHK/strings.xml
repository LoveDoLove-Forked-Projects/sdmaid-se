    <string name="squeezer_type_heic_title">HEIC/HEIF</string>
    <string name="squeezer_type_heic_description">包含 HEIC/HEIF 影像 (.heic, .heif)。日期、位置及其他 EXIF 中繼資料會保留。HDR 增益對應、深度資料和 Live/Motion Photo 相關檔案無法保留；多重影像檔案會略過。</string>
    <string name="squeezer_type_video_title">MP4 影片</string>
